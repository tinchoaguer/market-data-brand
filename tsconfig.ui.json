{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": true
  },
  "include": ["src/ui"],
  "exclude": ["src/ui/**/*.test.*", "src/ui/**/*.spec.*", "src/**/*.test.*"]
}
